# Claude Code Context Management (cache discipline — see CLAUDE.md Session Init Checklist)
# Disable 1M context; forces cache-friendly 200K window for higher cache hit rates
CLAUDE_CODE_DISABLE_1M_CONTEXT=1
# Trigger auto-compact at 50% context usage (not 80%) to maintain >90% cache hit rate
CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=50

# GitHub MCP Server Configuration
# Required for .mcp.json github server to function
# Get token at: https://github.com/settings/tokens
# Scopes needed: repo (read/write to repositories)
GITHUB_TOKEN=your_github_personal_access_token_here

# Optional: OpenAI Configuration
# Uncomment if using OpenAI models alongside Claude
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Debug Logging
# Set to 1 for verbose logging in Claude Code CLI
# DEBUG=0

# Setup Instructions:
# 1. Copy this file to .env (git-ignored, local only)
# 2. Fill in GITHUB_TOKEN value
# 3. Reload terminal or run: source .env
# 4. Verify: echo $GITHUB_TOKEN (should not be empty)
