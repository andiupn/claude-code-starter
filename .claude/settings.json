{
  "permissions": {
    "allow": [
      "Bash(powershell Get-Service*)",
      "Bash(powershell Get-Process*)",
      "Bash(powershell Get-EventLog*)",
      "Bash(powershell Get-WmiObject*)",
      "Bash(powershell Get-ChildItem*)",
      "Bash(powershell Get-Content*)",
      "Bash(powershell Get-ItemProperty*)",
      "Bash(powershell Test-Path*)",
      "Bash(powershell Get-Item*)",
      "Bash(wmic *)",
      "mcp__computer-use__screenshot",
      "mcp__computer-use__zoom",
      "mcp__computer-use__double_click",
      "mcp__computer-use__left_click",
      "mcp__computer-use__right_click",
      "mcp__computer-use__triple_click",
      "mcp__computer-use__type",
      "mcp__computer-use__key",
      "mcp__computer-use__scroll",
      "mcp__computer-use__mouse_move",
      "mcp__computer-use__cursor_position",
      "mcp__computer-use__hold_key",
      "mcp__computer-use__wait",
      "mcp__computer-use__request_access",
      "mcp__computer-use__list_granted_applications",
      "mcp__computer-use__open_application",
      "mcp__computer-use__read_clipboard",
      "Bash(powershell -Command Get-Service*)",
      "Bash(powershell -NoProfile -Command Get-*)",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_Preview__preview_logs",
      "mcp__Claude_in_Chrome__read_network_requests",
      "Bash(lsnrctl status)",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_network",
      "Bash(curl -s *)",
      "Bash(npm view *)",
      "Bash(npm list *)",
      "Bash(docker compose ps *)",
      "Bash(grep *)",
      "Bash(rm -rf active/**)",
      "mcp__Claude_Preview__preview_start",
      "mcp__Claude_Preview__preview_eval",
      "mcp__Claude_Preview__preview_click",
      "mcp__Claude_Preview__preview_fill"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tsc-check.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/env-guard.sh"
          }
        ]
      }
    ]
  }
}
